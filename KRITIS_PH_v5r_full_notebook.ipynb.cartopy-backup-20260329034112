    "\n",
    "        affected_population = float(bus_state.loc[bus_state[\"unserved\"], bus_pop_col].sum())\n",
    "        total_population_proxy = float(bus_state[bus_pop_col].sum())\n",
    "\n",
    "        rec = {\n",
